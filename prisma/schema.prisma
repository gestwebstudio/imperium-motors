// Схема БД. Источник правды — 1С; сайт хранит зеркало каталога.
// VIN — уникальный ключ синхронизации.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite" // dev. Для прода поменять на "postgresql" + DATABASE_URL
  url      = env("DATABASE_URL")
}

model Car {
  id           Int      @id @default(autoincrement())
  vin          String   @unique // ключ синхронизации с 1С
  brand        String
  model        String
  year         Int
  status       String   @default("in_stock") // in_stock | reserved | sold
  price        Int // в рублях, целое
  currency     String   @default("RUB")

  // характеристики
  fuel         String?
  drive        String?
  transmission String?
  acceleration String?
  power        String?
  maxSpeed     String?

  photos       Photo[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  lastSeenAt   DateTime @default(now()) // когда последний раз пришла из 1С

  @@index([status])
}

model Photo {
  id    Int    @id @default(autoincrement())
  url   String
  sort  Int    @default(0)
  car   Car    @relation(fields: [carId], references: [id], onDelete: Cascade)
  carId Int

  @@index([carId])
}

// Аккаунты сотрудников для входа в админку. Заводятся скриптом
// scripts/create-admin.mjs — публичной регистрации нет.
model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())

  news         News[]
}

model News {
  id          Int       @id @default(autoincrement())
  slug        String    @unique
  title       String
  excerpt     String
  body        String
  coverImage  String?
  status      String    @default("draft") // draft | published
  publishedAt DateTime?

  author      User?     @relation(fields: [authorId], references: [id])
  authorId    Int?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
}
