# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# claude skills (локальные, не коммитим)
.claude/skills/

# скачанные наборы скиллов (не часть приложения)
/grill me skills/
/impeccable skill/
/taste skills/
/impeccable-main.zip

# локальная dev-база (SQLite)
*.db

# файлы, загруженные через админку (обложки новостей и т.п.) — рантайм-данные,
# не часть репозитория
/public/uploads/
